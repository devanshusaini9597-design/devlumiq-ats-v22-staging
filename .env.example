# ─────────────────────────────────────────────────────────────────────────────
# Devlumiq ATS — Environment Configuration
#
# Quick start:
#   1. Copy this file to .env.local  (or .env for local dev)
#   2. Fill in DATABASE_URL, JWT_SECRET, NEXT_PUBLIC_APP_URL
#   3. npm run setup          (generates client, syncs schema, runs migrations, seeds)
#   4. npm run dev
#
# Demo accounts after seeding (all password: Demo@1234):
#   ADMIN:          admin@devlumiq.com
#   RECRUITER:      recruiter@devlumiq.com
#   HIRING_MANAGER: hiring@devlumiq.com
#   INTERVIEWER:    interviewer@devlumiq.com
#   VIEWER:         viewer@devlumiq.com
#   DEMO:           demo@devlumiq.com
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon / Supabase / Railway recommended)
# Generate: https://neon.tech  or  https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/devlumiq?sslmode=require"

# JWT secret — must be at least 32 random characters
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_64_CHAR_RANDOM_SECRET"

# Public app URL (used in email links and OAuth callbacks)
NEXT_PUBLIC_APP_URL="https://your-deployment.vercel.app"

# ── Judge0 Code Runner (optional BYOK — sandboxed multi-language) ───────────
# IMPORTANT: Coding questions do NOT execute on your server by default.
# Configure Judge0 for a real sandbox, or explicitly opt into the local runner.
# Self-host: https://github.com/judge0/judge0  or RapidAPI Judge0 CE
# JUDGE0_API_URL="https://ce.judge0.com"
# JUDGE0_API_KEY=""
# JUDGE0_USE_RAPIDAPI="false"
#
# Local node:vm fallback (JavaScript only) — OFF by default.
# node:vm is NOT a security boundary. Only enable for local/dev, never as a
# production substitute for Judge0 on internet-facing deployments.
# NOTE: runInContext timeout only bounds sync CPU; Promise microtask recursion
# can still hang the process — another reason not to use this in production.
# ASSESSMENT_CODE_RUNNER="true"   # opt-in local runner when Judge0 is not set
# ASSESSMENT_CODE_RUNNER="false"  # force all runners off (even if Judge0 is set)

# Demo one-click login (/api/auth/demo)
# OFF on customer production by default.
# Automatically ON for localhost and devlumiq-ats-v22-staging.vercel.app (no env needed).
# Optional overrides:
# ENABLE_DEMO_LOGIN="true"              # force on for any host
# ENABLE_DEMO_LOGIN="false"             # force off even on staging
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN="true"  # optional UI hint (staging host auto-shows the panel)

# Cron shared secret for /api/cron/retention (assessment expiry + reminders)
# CRON_SECRET="REPLACE_WITH_RANDOM_SECRET"

# ── Email / SMTP (optional — invite emails, password reset) ───────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="noreply@devlumiq.com"

# ==========================================
# PREMIUM FEATURES - Third Party Integrations
# ==========================================

# DocuSign E-Signature Integration
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi/v2.1"
DOCUSIGN_AUTH_SERVER="https://account-d.docusign.com"
DOCUSIGN_CLIENT_ID="your-docusign-client-id"
DOCUSIGN_CLIENT_SECRET="your-docusign-client-secret"
DOCUSIGN_ACCOUNT_ID="your-docusign-account-id"
DOCUSIGN_REDIRECT_URI="https://your-domain.vercel.app/api/auth/docusign/callback"

# Checkr Background Check Integration
CHECKR_API_URL="https://api.checkr.com/v1"
CHECKR_API_KEY="your-checkr-api-key"

# Google OAuth for Calendar Integration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://your-domain.vercel.app/api/auth/google/callback"

# Zapier Webhook Integration
ZAPIER_WEBHOOK_URL="https://hooks.zapier.com/hooks/catch/your-webhook-id"
ZAPIER_WEBHOOK_SECRET="your-zapier-webhook-secret"

# Chrome Extension API Key (for LinkedIn import authentication)
# Prefer creating a per-user token via POST /api/settings/extension-token (Admin).
# Env fallback: Bearer must match EXTENSION_API_KEY and maps to EXTENSION_API_USER_ID
# (or the first active ADMIN with an organization if USER_ID is unset).
EXTENSION_API_KEY="your-extension-api-key"
# EXTENSION_API_USER_ID="cuid-of-the-user-who-owns-imports"

# Optional LinkedIn OAuth app credentials (used to refresh Job Board access tokens)
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# Trust X-Forwarded-For / X-Real-IP for rate limiting (set true behind Vercel/nginx/etc.)
# Without this, forged X-Forwarded-For headers cannot reset rate-limit buckets.
TRUSTED_PROXY="true"

# Checkr Webhook Secret (optional, for webhook signature verification)
CHECKR_WEBHOOK_SECRET="your-checkr-webhook-secret"

# DocuSign Webhook Secret (optional, for Connect HMAC verification)
DOCUSIGN_WEBHOOK_SECRET="your-docusign-webhook-secret"

# ── Redis (optional — for distributed rate limiting) ─────────────────────────
# If set, rate limiting uses Redis instead of in-memory Map.
# Required for multi-instance deployments (auth endpoints use rateLimitAsync).
# npm install ioredis
# REDIS_URL="redis://localhost:6379"

# ── Error Monitoring / Sentry (optional) ─────────────────────────────────────
# Leave unset to disable Sentry (app works fine without it)
# NOTE: server-only — do NOT prefix with NEXT_PUBLIC_
SENTRY_DSN=""

# ── AI Features / OpenAI (optional) ──────────────────────────────────────────
# All features work without AI. When configured, AI enhances:
#   - Resume parsing (semantic extraction vs regex)
#   - Candidate ranking (AI scoring vs simple skill match)
#   - Candidate screening (AI verdict vs rule-based)
#   - Job description generation (AI-written vs template)
#   - Email drafting (AI-composed vs pre-built templates)
# Get your key: https://platform.openai.com/api-keys
# Cost: ~$0.15 per 1M tokens with gpt-4o-mini (~$1-5/month typical usage)
OPENAI_API_KEY=""
# Optional: override default model (gpt-4o-mini). Options: gpt-4o, gpt-3.5-turbo
# OPENAI_MODEL="gpt-4o-mini"

# ── File Storage (optional — default: local /public/uploads/) ────────────────
# Providers: "local" (default), "s3" (AWS S3), "r2" (Cloudflare R2)
FILE_STORAGE_PROVIDER="local"
# AWS S3 config (when FILE_STORAGE_PROVIDER=s3)
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="your-bucket-name"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# Cloudflare R2 config (when FILE_STORAGE_PROVIDER=r2)
# R2_ACCOUNT_ID="your-account-id"
# R2_BUCKET="your-bucket-name"
# R2_ACCESS_KEY_ID="your-r2-access-key"
# R2_SECRET_ACCESS_KEY="your-r2-secret-key"
# R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ── WhatsApp Business API (optional BYOK — leave blank = feature off) ─────────
# Existing buyers: no keys needed; send routes return 503 until configured.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Webhook verify token for GET /api/webhooks/whatsapp
WHATSAPP_VERIFY_TOKEN=""
# App secret for POST signature (X-Hub-Signature-256) — REQUIRED in production if WhatsApp is enabled
# WHATSAPP_APP_SECRET=""

# ── Twilio SMS (optional BYOK — leave blank = SMS off, email unchanged) ───────
# TWILIO_ACCOUNT_SID="ACxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_auth_token"
# TWILIO_PHONE_NUMBER="+15551234567"
# Optional override for inbound signature validation (defaults to TWILIO_AUTH_TOKEN)
# TWILIO_WEBHOOK_AUTH_TOKEN=""
# Exact public URL Twilio calls (needed if signature validation fails due to proxy/path)
# TWILIO_WEBHOOK_URL="https://your-domain.com/api/webhooks/twilio"
# Configure Twilio Messaging webhook → POST {APP_URL}/api/webhooks/twilio

# ── Web Push / PWA (optional BYOK — no-op without keys; careers apply still works) ─
# Generate VAPID keys: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:support@yourdomain.com"

# ── Meeting transcript webhooks (Zoom/Meet/Teams bots) — optional BYOK ────────
# REQUIRED in production if you expose /api/webhooks/meetings or /api/webhooks/recall
# MEETING_WEBHOOK_SECRET="shared-secret"
# Point bot → POST /api/webhooks/meetings with header X-Meeting-Secret

# ── Recall.ai meeting join bot (optional BYOK) ────────────────────────────────
# Sends a bot to Zoom/Meet/Teams via POST /api/interviews/[id]/meeting-bot
# RECALL_API_KEY="your_recall_api_key"
# Or store per-org under Settings → API keys (provider: recall)
# RECALL_REGION="us-east-1"   # us-east-1 | us-west-2 | eu-central-1 | ap-northeast-1
# Optional alias for webhook auth (defaults to MEETING_WEBHOOK_SECRET)
# RECALL_WEBHOOK_SECRET="shared-secret"
# Dashboard: set workspace webhook → POST {NEXT_PUBLIC_APP_URL}/api/webhooks/recall?token=...
# Subscribe to bot.done / transcript.done (status events are not sent via realtime_endpoints)

# ── Cron (transcript retention + interview push reminders) ────────────────────
# REQUIRED in production (endpoint is open in local/dev when unset)
# CRON_SECRET="long-random-string"
# Call GET/POST /api/cron/retention every 15–60 minutes with Authorization: Bearer CRON_SECRET

# ── Stripe Billing (optional — enables subscription plans + checkout) ──────
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_STARTER="price_..."
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."
# Optional add-on SKUs (existing buyers unaffected — unlock only when purchased)
# STRIPE_PRICE_WHITELABEL_KIT="price_..."
# STRIPE_PRICE_ANALYTICS_PLUS="price_..."
# STRIPE_PRICE_SSO="price_..."
# NEXT_PUBLIC_STRIPE_PRICE_WHITELABEL_KIT="price_..."
# NEXT_PUBLIC_STRIPE_PRICE_ANALYTICS_PLUS="price_..."
# NEXT_PUBLIC_STRIPE_PRICE_SSO="price_..."

# SAML SP entity ID override (defaults to {APP_URL}/api/auth/sso/metadata)
# SAML_SP_ENTITY_ID="https://your-ats.example.com/api/auth/sso/metadata"

# ── BYOK API Key Encryption (required for encrypted org API keys) ───────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY="64_char_hex_string"

# ── O*NET Web Services (optional BYOK — full taxonomy sync) ─────────────────
# Free registration: https://www.onetcenter.org/web_services.html
# ONET_USERNAME=""
# ONET_PASSWORD=""
# Or single basic auth style if you store as ONET_API_KEY="user:pass"
# ONET_API_KEY=""

