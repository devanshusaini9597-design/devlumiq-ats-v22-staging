# PostgreSQL (Required for Vercel Production)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# For local development:
# DATABASE_URL="file:./prisma/dev.db"

# JWT Secret for authentication (REQUIRED for portal/auth features)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Email SMTP Configuration (Required for email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_NAME="Recruitment Team"
FROM_EMAIL="hiring@company.com"

# App URL (Required for email links and callbacks)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ==========================================
# PREMIUM FEATURES - Third Party Integrations
# ==========================================

# DocuSign E-Signature Integration
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi/v2.1"
DOCUSIGN_AUTH_SERVER="https://account-d.docusign.com"
DOCUSIGN_CLIENT_ID="your-docusign-client-id"
DOCUSIGN_CLIENT_SECRET="your-docusign-client-secret"
DOCUSIGN_ACCOUNT_ID="your-docusign-account-id"
DOCUSIGN_REDIRECT_URI="https://your-domain.vercel.app/api/auth/docusign/callback"

# Checkr Background Check Integration
CHECKR_API_URL="https://api.checkr.com/v1"
CHECKR_API_KEY="your-checkr-api-key"

# Google OAuth for Calendar Integration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://your-domain.vercel.app/api/auth/google/callback"

# Zapier Webhook Integration
ZAPIER_WEBHOOK_URL="https://hooks.zapier.com/hooks/catch/your-webhook-id"

# Chrome Extension API Key (for LinkedIn import authentication)
EXTENSION_API_KEY="your-extension-api-key"

# Checkr Webhook Secret (optional, for webhook signature verification)
CHECKR_WEBHOOK_SECRET="your-checkr-webhook-secret"

# DocuSign Webhook Secret (optional, for Connect HMAC verification)
DOCUSIGN_WEBHOOK_SECRET="your-docusign-webhook-secret"

# Production Deployment URL (required for OAuth callbacks)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ==========================================
# PRODUCTION NEXT STEPS
# ==========================================
# 
# 1. DocuSign Production Setup:
#    - Create a DocuSign developer account at https://developers.docusign.com
#    - Create an Integration Key (Client ID)
#    - Generate RSA Key Pair for JWT authentication
#    - Update DOCUSIGN_BASE_URL to production: https://na2.docusign.net/restapi/v2.1
#    - Set up webhook endpoints in DocuSign Connect
#
# 2. Checkr Production Setup:
#    - Create a Checkr account at https://checkr.com
#    - Generate API keys from the dashboard
#    - Update CHECKR_API_URL to production: https://api.checkr.com/v1
#    - Configure webhook endpoints in Checkr dashboard
#
# 3. Google OAuth for Calendar:
#    - Create OAuth 2.0 credentials in Google Cloud Console
#    - Enable Google Calendar API
#    - Add authorized redirect URIs
#    - Implement the OAuth consent screen
#
# 4. Zapier Integration:
#    - Create a Zapier account
#    - Set up webhook URLs in Zapier
#    - Configure trigger events and actions
#
# 5. Chrome Extension:
#    - See CHROME_EXTENSION_README.md for setup instructions
#    - Create icons in chrome-extension/icons/ folder
#    - Load extension in Chrome developer mode for testing
#    - Publish to Chrome Web Store when ready
#
# 6. Additional Production Settings:
#    - Set up monitoring (e.g., Vercel Analytics, LogRocket)
#    - Configure error tracking (e.g., Sentry)
#    - Set up automated backups for database
#    - Configure CDN for static assets
#    - Set up rate limiting for API endpoints
#
# 7. Testing:
#    - Add unit tests for API routes (npm run test)
#    - Set up integration tests for webhooks
#    - Test OAuth flows in staging environment
#    - Verify Chrome Extension on different LinkedIn profiles

