# ─────────────────────────────────────────────────────────────
# .env.new-db.example
# Configuration for a NEW database (separate from the live site)
#
# IMPORTANT: This is a SEPARATE database from your production DB.
# Copy this to .env.local (or set in your hosting dashboard)
# BEFORE running: npm run db:new
# ─────────────────────────────────────────────────────────────

# ── NEW Database URL ──────────────────────────────────────────
# Create a new Neon / Supabase / Railway / PlanetScale database
# and paste the connection string here.
# Example (Neon):
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/devlumiq_rbac?sslmode=require"

# ── JWT Secret ────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_64_CHAR_RANDOM_SECRET"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-new-deployment.vercel.app"

# ── Optional: Email (for invite emails) ──────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="noreply@devlumiq.com"

# ─────────────────────────────────────────────────────────────
# Setup Steps (new database from scratch):
#
#   1. Create a new PostgreSQL database (Neon recommended)
#   2. Set DATABASE_URL above
#   3. npx prisma migrate deploy     — runs all migrations
#   4. npm run seed:new               — seeds all 5 role users + sample data
#   5. npm run dev                    — start dev server
#
# Test Accounts after seeding:
#   ADMIN:           admin@devlumiq.com         / Admin@123
#   RECRUITER:       recruiter@devlumiq.com     / Recruit@123
#   HIRING_MANAGER:  hiring@devlumiq.com        / Hiring@123
#   INTERVIEWER:     interviewer@devlumiq.com   / Interview@123
#   VIEWER:          viewer@devlumiq.com        / Viewer@123
#   DEMO:            demo@devlumiq.com          / demo
# ─────────────────────────────────────────────────────────────
